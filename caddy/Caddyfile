# The DMS. Our own app now -- Nextcloud is gone, and with it the /.well-known
# carddav/caldav redirects, which only ever existed to satisfy Nextcloud clients.
drive.vulcanoffice.com {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
        resolvers 1.1.1.1
    }
    encode gzip zstd
    request_body {
        max_size 50GB
    }

    reverse_proxy app:3000 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host {host}
    }

    header {
        ?Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        ?Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), interest-cohort=(), unload=*"
        -Feature-Policy
        ?Cross-Origin-Opener-Policy "same-origin"
        ?X-Robots-Tag "noindex, nofollow"
    }
}

# The editor. This is the ONLY route from the internet to the Document Server: it
# publishes no host port and sits on the internal `frontnet`. Everything the browser
# needs arrives through here -- api.js (the DocsAPI entrypoint the app <script>-loads),
# the editor assets, and the collaborative-editing WebSocket, which reverse_proxy
# upgrades automatically.
office.vulcanoffice.com {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
        resolvers 1.1.1.1
    }
    encode gzip zstd
    request_body {
        # Uploads reach the editor as document downloads/saves, not as request bodies,
        # but conversion callbacks can be chunky. 100MB is the upstream default.
        max_size 100MB
    }
    reverse_proxy documentserver:80 {
        # -1 disables response buffering. The Document Server long-polls and streams;
        # buffering here desyncs co-editing sessions.
        flush_interval -1
        transport http {
            keepalive 30s
        }
    }

    header {
        Permissions-Policy "unload=*"
    }
}
