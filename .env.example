# Copy to .env and fill in. Never commit .env -- it is gitignored.
#
# Every value below is consumed by docker-compose.yml with the `${VAR:?...}` form,
# so a missing one fails the deploy immediately instead of silently starting a
# half-configured stack.

# --- Caddy ---------------------------------------------------------------------
# Cloudflare token for the DNS-01 ACME challenge.
CF_API_TOKEN=

# --- Document Server (our AGPL build) -------------------------------------------
# Image built by .github/workflows/build-documentserver.yml, or locally via
# scripts/rebrand.sh + docker buildx bake.
VO_DS_IMAGE=ghcr.io/freddominugez/vulcan-office-documentserver:9.3.2-vulcan.1-arm64

# Shared secret. The Document Server signs its callbacks with it and verifies the
# app's requests with it; the app does the mirror image. Both sides MUST match.
# Generate with: openssl rand -hex 32
VO_JWT_SECRET=

# --- vulcan-drive (the app that replaced Nextcloud) ------------------------------
VO_APP_IMAGE=ghcr.io/freddominugez/vulcan-drive:latest

# --- Postgres / Redis ------------------------------------------------------------
DB_PWD=
REDIS_PWD=

# --- Backblaze B2 (user files) ---------------------------------------------------
# S3-compatible. Already the store of record; Nextcloud used the same bucket.
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_BUCKET=vulcan-office-nextcloud
B2_KEY_ID=
B2_APP_KEY=

# --- AI gateway ------------------------------------------------------------------
VULCAN_PLATFORM_SECRET=
AI_GATEWAY_URL=https://admin.byvulcan.com/api/ai-gateway
