# Cloudflare token for Caddy DNS-01 challenge
CF_API_TOKEN=

# MariaDB (root + nextcloud user reuse the same password)
DB_PWD=

# Redis auth
REDIS_PWD=

# Nextcloud initial admin
NC_ADMIN_PWD=

# Oracle Object Storage S3-compatible credentials for Nextcloud primary storage
OCI_S3_KEY=
OCI_S3_SECRET=

# Euro-Office DocumentServer JWT (must match the value stored in the
# Nextcloud `vulcanoffice` connector settings)
EO_JWT_SECRET=

# NOTE: the upstream-update watcher (see scripts/check-eurooffice-updates.sh)
# reads its SMTP config from a separate file at /etc/vulcan/eurooffice-check.env
# See systemd/eurooffice-check.env.example for the template.
