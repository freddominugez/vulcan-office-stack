# Deploy this file to /etc/vulcan/eurooffice-check.env with real values.
# Read by /usr/local/bin/check-eurooffice-updates.sh.

NOTIFY_EMAIL=freddominguez@gmail.com

SES_FROM=noreply@vulcanoffice.com
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_USER=
SES_SMTP_PASS=

# Optional overrides
# COMPOSE_FILE=/opt/vulcan-office-stack/docker-compose.yml
# STATE_DIR=/var/lib/vulcan
# LOG_FILE=/var/log/vulcan/eurooffice-updates.log
