# brand.env - single source of truth for the Vulcan Office brand.
#
# Sourced by scripts/rebrand.sh and by the CI build workflow. Every brand string
# in the Document Server derives from here; nothing is hard-coded downstream.
#
# The upstream build reads most of these straight from the environment:
#   - web-apps  : build/theme.config.mjs   (env var > theme config.json > default)
#   - server    : server.bake.Dockerfile   (ENV APP_NAME=${COMPANY_NAME})
#   - packages  : document-server-package/Makefile (all vars are `?=`)

# Company / product. COMPANY_NAME_LOW is derived by the bake file as
# lower(COMPANY_NAME) with whitespace -> "-", so this yields "vulcan-office"
# and install paths become /var/www/vulcan-office/documentserver.
COMPANY_NAME="Vulcan Office"
PRODUCT_NAME="DocumentServer"
APP_TITLE_TEXT="Vulcan Office"

# web-apps theme directory name (web-apps/theme/<THEME>/), selected at build time.
THEME="vulcan-office"

# AGPL-3.0 section 13: the public repository carrying the complete corresponding
# source of this service. Rendered as a clickable link in the editor's About dialog.
PUBLISHER_NAME="Vulcan"
PUBLISHER_URL="https://github.com/freddominugez/vulcan-office-stack"
SUPPORT_URL="https://github.com/freddominugez/vulcan-office-stack"
HELP_URL="https://github.com/freddominugez/vulcan-office-stack"
SUPPORT_MAIL="support@vulcanoffice.com"

# Deliberately blank: the upstream defaults are Ascensio's Riga office address and
# phone number. Blank hides the row rather than showing someone else's contact.
PUBLISHER_ADDRESS=""
PUBLISHER_PHONE=""
SALES_EMAIL=""
SUPPORT_EMAIL=""

# AGPL-3.0 section 7(b) attribution. Preserves credit to Ascensio System SIA and to
# Euro-Office, and states that the link is the source code OF THIS SERVICE (section 13).
# Removing the Ascensio credit here would be a licence violation -- do not shorten it.
ATTRIBUTION="Vulcan Office is a rebranded build of Euro-Office, which is based on ONLYOFFICE by Ascensio System SIA. Licensed under AGPL-3.0. The complete corresponding source code of this service is available at https://github.com/freddominugez/vulcan-office-stack"

# Container image published by CI (AGPL, public).
REGISTRY="ghcr.io/freddominugez"
IMAGE_NAME="vulcan-office-documentserver"
